# =============================================================================
# Configurações do Servidor — server-setup
# Copie este arquivo para .env e ajuste os valores antes de executar
# =============================================================================

# ─── Sistema ───────────────────────────────────────────────────────────────

# Nome do host do servidor (aparece no terminal e no Cockpit)
SERVER_HOSTNAME=meu-servidor

# Fuso horário (padrão Brasil; lista: timedatectl list-timezones)
TIMEZONE=America/Sao_Paulo

# ─── Rede / mDNS ───────────────────────────────────────────────────────────

# Domínio local via Avahi (mDNS). O servidor ficará acessível como este nome.
# Formato: nome.local  (ex: empresa.local, escritorio.local)
# Avahi publicará o servidor com o sufixo .local automaticamente.
LOCAL_DOMAIN=empresa.local

# ─── SSH ───────────────────────────────────────────────────────────────────

# Porta SSH (padrão 22). Use outra porta se o servidor for exposto à internet.
SSH_PORT=22

# Chave pública SSH do administrador (conteúdo do arquivo ~/.ssh/id_ed25519.pub)
# OBRIGATÓRIO para desativar autenticação por senha.
# Se deixado vazio, a senha ficará ATIVA como fallback temporário.
SSH_PUBLIC_KEY=""

# ─── Web / Arquivos ────────────────────────────────────────────────────────

# Diretório raiz onde ficam os sites
WEB_ROOT=/srv/sites

# Diretório onde os backups são armazenados
BACKUP_DIR=/srv/backups

# ─── PHP ───────────────────────────────────────────────────────────────────

# Versão do PHP a instalar (via ppa:ondrej/php)
PHP_VERSION=8.3

# ─── Node.js ───────────────────────────────────────────────────────────────

# Versão principal do Node.js (via NodeSource)
NODEJS_VERSION=22

# ─── MariaDB ───────────────────────────────────────────────────────────────

# Senha root do MariaDB.
# Se deixado vazio, uma senha segura será gerada automaticamente
# e salva em /root/.server-credentials
MARIADB_ROOT_PASSWORD=""

# ─── Notificações ──────────────────────────────────────────────────────────

# E-mail do administrador para alertas de atualização automática (opcional)
ADMIN_EMAIL=""
